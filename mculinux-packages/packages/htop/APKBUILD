# Contributor: MCUlinux <dev@mculinux.org>
# Maintainer: MCUlinux <dev@mculinux.org>
pkgname=htop
pkgver=3.3.0
pkgrel=0
pkgdesc="Interactive process viewer"
url="https://htop.dev"
arch="xtensa"
license="GPL-2.0-only"
depends="musl ncurses"
makedepends="linux-headers"
subpackages="$pkgname-doc"
source="https://github.com/htop-dev/htop/releases/download/$pkgver/htop-$pkgver.tar.gz"

build() {
    cd "$srcdir/htop-$pkgver"

    # ESP32-S3 specific flags
    export CFLAGS="$CFLAGS -Os -mtext-section-literals"
    export LDFLAGS="$LDFLAGS -mlongcalls"

    ./configure \
        --host=xtensa-esp32s3-elf \
        --prefix=/usr \
        --disable-unicode \
        --disable-static

    make -j$(nproc)
}

package() {
    cd "$srcdir/htop-$pkgver"
    make DESTDIR="$pkgdir" install

    # Remove unnecessary files
    rm -rf "$pkgdir/usr/share/man"
}
