# Maintainer: MCUlinux <dev@mculinux.org>
pkgname=bash
pkgver=5.2.32
pkgrel=0
pkgdesc="GNU Bourne Again Shell"
url="https://www.gnu.org/software/bash/"
arch="xtensa"
license="GPL-3.0-only"
depends="musl ncurses readline"
makedepends="linux-headers"
subpackages="$pkgname-doc"
source="https://ftp.gnu.org/gnu/bash/bash-$pkgver.tar.gz"

build() {
    cd "$srcdir/bash-$pkgver"

    # ESP32-S3 specific flags
    export CFLAGS="$CFLAGS -mtext-section-literals"
    export LDFLAGS="$LDFLAGS -mlongcalls"

    ./configure \
        --host=xtensa-esp32s3-elf \
        --prefix=/usr \
        --disable-nls \
        --disable-profiling \
        --disable-readline \
        --without-bash-malloc \
        --with-curses \
        --enable-static-link

    make -j$(nproc)
}

package() {
    cd "$srcdir/bash-$pkgver"
    make DESTDIR="$pkgdir" install

    # Create bash symlink
    ln -sf bash "$pkgdir/usr/bin/sh"

    # Remove unnecessary files
    rm -rf "$pkgdir/usr/share/man"
}
