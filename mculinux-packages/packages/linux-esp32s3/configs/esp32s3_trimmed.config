# MCUlinux ESP32-S3 Kernel Config Fragment
# Applied after esp32s3_devkit_c1_defconfig
# Optimized for 8MB flash ESP32-S3 with EROFS+LZMA rootfs

# === Filesystem ===
CONFIG_EROFS_FS=y
CONFIG_EROFS_FS_ZIP=y
CONFIG_EROFS_FS_ZIP_LZMA=y
CONFIG_EROFS_FS_XATTR=y
CONFIG_EROFS_FS_POSIX_ACL=y
CONFIG_EROFS_FS_SECURITY=y
CONFIG_EROFS_FS_BACKED_BY_FILE=y

# === Size optimizations ===
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_LD_DEAD_CODE_DATA_ELIMINATION=y

# === Remove large subsystems to save RAM ===
# NFS (huge, not needed for flash boot)
CONFIG_NFS_FS=n
CONFIG_LOCKD=n
CONFIG_SUNRPC=n
CONFIG_NETWORK_FILESYSTEMS=n

# BPF (not needed)
CONFIG_BPF=n

# JFFS2 (we use EROFS)
CONFIG_JFFS2_FS=n

# Key management (not needed)
CONFIG_KEYS=n
CONFIG_ASYMMETRIC_KEY_TYPE=n
CONFIG_X509_CERTIFICATE_PARSER=n
CONFIG_PKCS7_MESSAGE_PARSER=n
CONFIG_SYSTEM_DATA_VERIFICATION=n
CONFIG_SYSTEM_TRUSTED_KEYRING=n

# Perf/events (not needed)
CONFIG_PERF_EVENTS=n
CONFIG_DEBUG_FS=n
CONFIG_DEBUG_KERNEL=n
CONFIG_BLK_DEBUG_FS=n

# Futex PI (not needed for single core)
CONFIG_FUTEX_PI=n

# Network diagnostics
CONFIG_PACKET=n
CONFIG_PACKET_DIAG=n
CONFIG_INET_DIAG=n
CONFIG_UNIX_DIAG=n

# XZ decoder arch-specific (only keep generic)
CONFIG_XZ_DEC_ARM=n
CONFIG_XZ_DEC_ARM64=n
CONFIG_XZ_DEC_ARMTHUMB=n
CONFIG_XZ_DEC_BCJ=n
CONFIG_XZ_DEC_MICROLZMA=n
CONFIG_XZ_DEC_POWERPC=n
CONFIG_XZ_DEC_RISCV=n
CONFIG_XZ_DEC_SPARC=n
CONFIG_XZ_DEC_X86=n

# Misc bloat
CONFIG_MAGIC_SYSRQ=n
CONFIG_MAGIC_SYSRQ_SERIAL=n
CONFIG_LEGACY_PTYS=n
CONFIG_LEGACY_TIOCSTI=n
CONFIG_PRINT_USER_CODE_ON_UNHANDLED_EXCEPTION=n
CONFIG_PROC_MEM_ALWAYS_FORCE=n
CONFIG_MTD_CFI_I1=n
CONFIG_MTD_CFI_I2=n

# === ESP32-S3 specific ===
CONFIG_COMMON_CLK_ESP32S3=y
CONFIG_SERIAL_ESP32=y
CONFIG_SERIAL_ESP32_ACM=y
CONFIG_GPIO_ESP32=y
CONFIG_SPI_ESP32=y
CONFIG_HW_RANDOM_ESP32=y
CONFIG_ESP32_WIFI=y
CONFIG_ESP32_WIFI_SHMEM=y
CONFIG_ESP32_INTC=y
CONFIG_ESP32_IPC=y
CONFIG_MTD_ESP32=y
CONFIG_PHY_ESP32S3_USB=y
CONFIG_USB=y
CONFIG_USB_SUPPORT=y
CONFIG_USB_DWC2=y
CONFIG_USB_DWC2_HOST=y
CONFIG_USB_ROLE_SWITCH=y
CONFIG_USB_COMMON=y
CONFIG_USB_ACM=y

# === XIP (execute in place) ===
CONFIG_XIP_KERNEL=y
