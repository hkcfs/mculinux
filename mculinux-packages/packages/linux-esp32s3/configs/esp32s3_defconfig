# MCUlinux ESP32-S3 Kernel Config Fragment
# This is applied on top of xtensa-esp32s3_defconfig

# Xtensa architecture
CONFIG_XTENSA_VARIANT_CUSTOM=y
CONFIG_XTENSA_VARIANT_CUSTOM_NAME="esp32s3"
CONFIG_XTENSA_PLATFORM_ESP32=y
CONFIG_XIP_KERNEL=y
CONFIG_KERNEL_LOAD_ADDRESS=0x42120000
CONFIG_XIP_DATA_ADDR=0x3d800000
CONFIG_DEFAULT_MEM_START=0x3d800000
CONFIG_MEMMAP_CACHEATTR=0xffff222f
CONFIG_BUILTIN_DTB_NAME="esp32s3-devkit-c1"

# Optimizations
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_LD_DEAD_CODE_DATA_ELIMINATION=y

# Memory
CONFIG_MTD=y
CONFIG_MTD_BLOCK=y
CONFIG_MTD_ESP32=y
CONFIG_MTD_PHYSMAP=y
CONFIG_MTD_PHYSMAP_OF=y

# Serial
CONFIG_SERIAL_ESP32=y
CONFIG_SERIAL_ESP32_ACM=y

# GPIO
CONFIG_GPIOLIB=y
CONFIG_GPIO_SYSFS=y
CONFIG_GPIO_ESP32=y

# SPI
CONFIG_SPI=y
CONFIG_SPI_ESP32=y

# Hardware
CONFIG_HW_RANDOM_ESP32=y
CONFIG_I2C=y
CONFIG_I2C_GPIO=y

# Clock
CONFIG_COMMON_CLK_ESP32S3=y
CONFIG_RESET_CONTROLLER=y
CONFIG_RESET_SIMPLE=y

# Network
CONFIG_NET=y
CONFIG_INET=y
CONFIG_NETDEVICES=y
CONFIG_ESP32_WIFI=y
CONFIG_CFG80211=y
CONFIG_RFKILL=y

# Filesystem
CONFIG_EROFS_FS=y
CONFIG_EROFS_FS_ZIP=y
CONFIG_EROFS_FS_ZIP_LZMA=y
CONFIG_JFFS2_FS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# Init
CONFIG_INITRAMFS_SOURCE=""
CONFIG_BLK_DEV_INITRD=y

# Debugging
CONFIG_PRINTK_TIME=y
CONFIG_MAGIC_SYSRQ=y
CONFIG_DEBUG_FS=y
